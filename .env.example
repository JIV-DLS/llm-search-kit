# Copy to .env and fill in.
# llm-search-kit talks to ANY OpenAI-compatible chat-completions endpoint.

# --- OpenAI ---
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# --- Groq ---
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile

# --- OpenRouter ---
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-...
# LLM_MODEL=anthropic/claude-3.5-sonnet

# --- Local Ollama (OpenAI-compatible mode) ---
# Notes:
#   * Make sure Ollama is running (`ollama serve`) and has the model pulled
#     (`ollama pull qwen2.5:1.5b`).
#   * Mind the `/v1` suffix on the URL — that's what enables OpenAI-compat.
#   * LLM_API_KEY can be left empty for local servers; the kit auto-detects
#     localhost / 127.0.0.1 / *.local hosts as keyless. Setting it to the
#     literal string "ollama" also works.
#   * For tool-calling, prefer models that advertise it: qwen2.5:1.5b is
#     a good lightweight default; qwen2.5:7b is heavier but more capable.
#     Avoid models without tool support (e.g. plain llama3.2:1b).
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=
# LLM_MODEL=qwen2.5:1.5b

# --- Optional fallback provider (used by ResilientLLMClient if configured) ---
# LLM_FALLBACK_BASE_URL=
# LLM_FALLBACK_API_KEY=
# LLM_FALLBACK_MODEL=

# --- Real-estate example only ---
# REAL_ESTATE_API_URL=https://your-backend.example.com/api/v1/smart-search/intelligent
